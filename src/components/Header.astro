---
import Nav from "../components/Nav.astro";
import Button from "../components/Button.astro";
---

<header
  class="sticky top-0 z-10 col-start-1 col-end-4 row-start-1 flex h-[var(--nav-height)] items-baseline justify-start bg-white/95 backdrop-blur-sm px-4 shadow-sm"
>
  <a href="/" class="flex h-full items-center">
    <span class="text-2xl font-bold text-slate-700">nathantranquilla</span><span
      class="text-2xl font-bold text-lime-700">.me</span
    >
  </a>
  <Nav />
  <Button
    href="/consultation"
    classes="hidden md:block ml-auto flex items-center self-center"
    >Work With Me</Button
  >
</header>
