---
export interface Props {
  title: string;
  link?: string;
}
const { title, link } = Astro.props;
import H3 from "./HTMLElements/H3.astro";
import RightArrow from "./RightArrow.astro";
---

<div
  class="flex min-h-[400px] flex-col items-stretch justify-start rounded-lg border border-[var(--border-secondary)] bg-[var(--bg-primary)] p-6 font-sans text-[var(--text-primary)] shadow-lg hover:shadow-xl transition-shadow duration-200 md:p-8"
>
  <H3 classes="w-full flex justify-start items-center pb-4">
    {title}
  </H3>
  <slot />
  <div class="grow"></div>
  <a
    href={link || undefined}
    aria-disabled={!link ? "true" : "false"}
    class={`mt-6 flex items-center font-semibold ${
      link
        ? "text-[var(--text-accent)] hover:text-[var(--text-accent-hover)]"
        : "text-[var(--text-muted)] cursor-not-allowed"
    }`}>Learn More <RightArrow /></a
  >
</div>
