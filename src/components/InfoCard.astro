---
export interface Props {
  title: string;
  link?: string;
}
const { title, link } = Astro.props;
import H3 from "./HTMLElements/H3.astro";
import RightArrow from "./RightArrow.astro";
---

<div
  class="flex min-h-[400px] flex-col items-stretch justify-start rounded-lg border border-slate-100 bg-white p-6 font-sans text-slate-900 shadow-lg hover:shadow-xl transition-shadow duration-200 md:p-8"
>
  <H3 classes="w-full flex justify-start items-center pb-4">
    {title}
  </H3>
  <slot />
  <div class="grow"></div>
  <a
    href={link || undefined}
    aria-disabled={!link ? "true" : "false"}
    class={`mt-6 flex items-center font-semibold ${
      link
        ? "text-lime-700 hover:text-lime-800"
        : "text-slate-400 cursor-not-allowed"
    }`}>Learn More <RightArrow /></a
  >
</div>
