---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import Profile from "../assets/Profile.webp";
import Container from "./Container.astro";
---

<Container
  classes="w-full h-fit flex flex-col justify-start items-center pt-[5vh] md:max-w-[640px] max-w-[350px] mx-auto"
>
  <figure class="h-[200px] w-[200px] md:h-[400px] md:w-[400px]">
    <Image
      src={Profile}
      alt="Nathan Tranquilla Profile"
      class="rounded-full shadow-xl"
      widths={[350, 550]}
      layout="constrained"
    />
  </figure>
  <h1
    class="text-lg pt-4 font-serif font-semibold text-nowrap text-[var(--text-primary)] md:text-3xl"
  >
    Nathan Tranquilla | Web Developer
  </h1>
  <p class="w-full py-4 font-sans text-[var(--text-secondary)] md:text-xl">
    I help small businesses stand out online with fast, custom websites
    that bring in customers and make a great first impression.
  </p>
  <Button href="/consultation">Work With Me</Button>
</Container>
