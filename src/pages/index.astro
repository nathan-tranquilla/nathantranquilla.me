---
import Main from "../layouts/Main.astro";
import Hero from "../components/Hero.astro";
import Container from "../components/Container.astro";
import H2 from "../components/HTMLElements/H2.astro";
import H3 from "../components/HTMLElements/H3.astro";
import RightArrow from "../components/RightArrow.astro";
import { getPosts } from "../utils/posts";

const posts = getPosts().slice(0, 3);

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const projects = [
  {
    name: "Magnolia Coast Photography",
    url: "https://magnoliacoastsphotography.com",
    image: "https://magnoliacoastsphotography.com/_astro/Logo.BGOeOxRg.png",
    description:
      "A photography portfolio and client showcase website for Magnolia Coast Photography, featuring gallery displays and a seamless booking experience.",
  },
  {
    name: "The Office Lines",
    url: "https://theofficelines.com",
    image: "https://theofficelines.com/og-default.png",
    description:
      "A fan site packed with memorable quotes and lines from The Office, with searchable content and daily featured scenes.",
  },
];
---

<Main
  title="nathantranquilla.me | Web Developer"
  description="Nathan Tranquilla is a web developer building high-performance, reliable, and maintainable web applications."
>
  <Hero />

  <div class="bg-[var(--bg-secondary)]">
  <Container classes="w-full max-w-4xl mx-auto">
    <H2 classes="mb-8 text-[var(--text-primary)]">Projects</H2>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <div class="flex flex-col overflow-hidden rounded-lg border border-[var(--border-secondary)] bg-[var(--bg-primary)] shadow-lg transition-shadow duration-200 hover:shadow-xl">
            <img
              src={project.image}
              alt={`${project.name} screenshot`}
              class="h-48 w-full object-cover"
            />
            <div class="flex grow flex-col p-6 md:p-8">
            <H3 classes="pb-4">{project.name}</H3>
            <p class="grow font-sans text-[var(--text-secondary)]">
              {project.description}
            </p>
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 flex items-center font-semibold text-[var(--text-accent)] hover:text-[var(--text-accent-hover)]"
            >
              Visit Site
              <RightArrow />
            </a>
            </div>
          </div>
        ))
      }
    </div>
  </Container>

  <Container classes="w-full max-w-4xl mx-auto">
    <H2 classes="mb-8 text-[var(--text-primary)]">Recent Posts</H2>
    <div class="divide-y divide-[var(--border-primary)]">
      {
        posts.map((post) => (
          <article class="py-6 first:pt-0">
            <a href={post.url} class="group block">
              <h3 class="mb-1 font-serif text-lg text-[var(--text-primary)] transition-colors duration-200 group-hover:text-[var(--text-accent)] md:text-xl">
                {post.frontmatter.title}
              </h3>
              <span class="text-sm text-[var(--text-muted)]">
                {post.frontmatter.author} · {formatDate(post.frontmatter.date)}
              </span>
            </a>
          </article>
        ))
      }
    </div>
    <a
      href="/blogs"
      class="mt-6 inline-flex items-center font-semibold text-[var(--text-accent)] hover:text-[var(--text-accent-hover)]"
    >
      View all posts
      <RightArrow />
    </a>
  </Container>
  </div>
</Main>
