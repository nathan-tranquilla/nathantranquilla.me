---
import "../styles/global.css";
import Body from "../components/Body.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

// Import logo assets
import logo16 from "../assets/logo_16x16.jpg";
import logo32 from "../assets/logo_32x32.jpg";
import logo48 from "../assets/logo_48x48.jpg";
import logo96 from "../assets/logo_96x96.jpg";
import logo180 from "../assets/logo_180x180.jpg";
import logo192 from "../assets/logo_192x192.jpg";
import logo256 from "../assets/logo_256x256.jpg";
import logo512 from "../assets/logo_512x512.jpg";
import ogImageDefault from "../assets/Profile.webp";

export interface Props {
  title: string;
  classes?: string;
  nonav?: boolean;
  description?: string;
  ogImage?: string;
  ogType?: string;
  breadcrumbTitle?: string;
}

const defaultDescription = "Nathan Tranquilla is a Next-Gen Web Development Consultant specializing in making web applications more robust through technology choices of the future";

const { title, classes, nonav = false, description = defaultDescription, ogImage, ogType = "website", breadcrumbTitle } = Astro.props;

const websiteUrl = "https://nathantranquilla.me";
const canonicalUrl = new URL(Astro.url.pathname, websiteUrl).href;
const ogImageUrl = ogImage || new URL(ogImageDefault.src, websiteUrl).href;
const isProd = import.meta.env.PROD;

// Generate breadcrumb schema
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": websiteUrl }
];

pathSegments.forEach((segment, index) => {
  const name = breadcrumbTitle && index === pathSegments.length - 1
    ? breadcrumbTitle
    : segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": index + 2,
    "name": name,
    "item": `${websiteUrl}/${pathSegments.slice(0, index + 1).join('/')}`
  });
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};
---

<html lang="en">
  <head>
    {isProd && (
      <Fragment>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-MCZFYVP6CG"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag("js", new Date());
          gtag("config", "G-MCZFYVP6CG");
        </script>
      </Fragment>
    )}
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=2"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1a1a1a" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Nathan Tranquilla" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="nathantranquilla.me" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon and Icons -->
    <link rel="icon" type="image/jpeg" sizes="16x16" href={logo16.src} />
    <link rel="icon" type="image/jpeg" sizes="32x32" href={logo32.src} />
    <link rel="icon" type="image/jpeg" sizes="48x48" href={logo48.src} />
    <link rel="icon" type="image/jpeg" sizes="96x96" href={logo96.src} />

    <!-- Apple Touch Icons -->
    <link rel="apple-touch-icon" sizes="180x180" href={logo180.src} />

    <!-- Android/Chrome Icons -->
    <link rel="icon" type="image/jpeg" sizes="192x192" href={logo192.src} />
    <link rel="icon" type="image/jpeg" sizes="256x256" href={logo256.src} />
    <link rel="icon" type="image/jpeg" sizes="512x512" href={logo512.src} />

    <!-- Default favicon -->
    <link rel="shortcut icon" href={logo32.src} />

    <meta name="email" content="tranquilla.nathan@pm.me" />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="keywords" content="Next-Gen Web Development, ReScript, TypeScript alternatives, strong type systems, web development consulting, type-safe programming, functional programming, web app development, static typing, JavaScript alternatives, web development consultant, AI consulting, software engineering, Nathan Tranquilla" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <Body>
    {!nonav && <Header />}
    <main class={`col-start-1 col-end-4 row-start-2 ${classes || ""}`}>
      {!nonav && <Breadcrumb title={breadcrumbTitle} />}
      <slot />
    </main>
    {!nonav && <Footer />}
  </Body>


</html>
