---
import Main from "./Main.astro";
import Container from "../components/Container.astro";
import { getPostIndex } from "../utils/posts";
import ViewCount from "../components/ViewCount.astro";

const { frontmatter } = Astro.props;

const i = getPostIndex(frontmatter.title);
const tagString = frontmatter.tags?.length ? ` — ${frontmatter.tags.join(", ")}` : "";
const blogDescription = frontmatter.description || `${frontmatter.title}${tagString} — by ${frontmatter.author}`;
const websiteUrl = "https://nathantranquilla.me";
const articleUrl = new URL(Astro.url.pathname, websiteUrl).href;

// Load build-time analytics data
let viewCount = 0;
try {
  const fs = await import("node:fs");
  const path = await import("node:path");
  const analyticsPath = path.join(process.cwd(), "public", "data", "analytics.json");
  if (fs.existsSync(analyticsPath)) {
    const viewCounts: Record<string, number> = JSON.parse(fs.readFileSync(analyticsPath, "utf-8"));
    viewCount = viewCounts[Astro.url.pathname.replace(/\/$/, "")] ?? 0;
  }
} catch {
  // Analytics data not available
}
---

<style is:global>
  /* Headings */
  .blog-post article h3 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .blog-post article h4 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .blog-post article h3 {
      font-size: 1.5rem;
    }

    .blog-post article h4 {
      font-size: 1.25rem;
    }
  }

  /* Paragraphs */
  .blog-body p {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  /* First paragraph in blog body */
  .blog-body > p:first-child {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.8;
  }

  /* Lists */
  .blog-post article ul {
    margin: 2rem 0;
    padding-left: 1.5rem;
    list-style: none;
  }

  .blog-post article ul li {
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .blog-post article ul li::before {
    content: "\25B8";
    color: var(--accent-strong);
    font-weight: bold;
    position: absolute;
    left: 0;
    top: 0;
    font-size: 1.2rem;
  }

  /* Ordered lists */
  .blog-post article ol {
    margin: 2rem 0;
    padding-left: 1.5rem;
    list-style: decimal;
  }

  .blog-post article ol li {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  /* Images */
  .blog-post article img {
    width: 100%;
    max-width: 900px;
    margin: 3rem auto;
    display: block;
    border-radius: 1rem;
    box-shadow:
      0 25px 50px -12px var(--shadow-heavy),
      0 10px 20px -8px var(--shadow-color);
    content-visibility: auto;
    border: 1px solid var(--border-primary);
  }

  /* Blockquotes */
  .blog-post article blockquote {
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--bg-secondary) 100%);
    border-left: 5px solid var(--accent-strong);
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: var(--text-tertiary);
    box-shadow: 0 4px 6px -1px var(--shadow-color);
  }

  /* Links */
  .blog-body a {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-color: var(--text-accent);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .blog-body a:hover {
    color: var(--text-accent-hover);
    text-decoration-color: var(--accent-strong);
  }

  /* Strong text */
  .blog-body strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  /* Tighten gap after headings */
  .blog-body h3 + p {
    margin-top: 1rem;
  }

  /* Figcaptions */
  .blog-post article figcaption {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.5rem;
    text-align: center;
  }

  /* Inline code */
  .blog-body :not(pre) > code {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
    font-size: 0.875em;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    border: 1px solid var(--border-primary);
  }

  /* Blog post layout */
  .blog-post {
    min-height: 100vh;
  }
</style>
<Main title={`nathantraquilla.me | ${frontmatter.title}`} description={blogDescription} ogType="article" breadcrumbTitle={frontmatter.title}>
  <Container classes="blog-post w-full max-w-[1000px] mx-auto font-sans">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": frontmatter.title,
      "description": blogDescription,
      "author": {
        "@type": "Person",
        "name": frontmatter.author,
        "url": `${websiteUrl}/about`
      },
      "publisher": {
        "@type": "Organization",
        "name": "Nathan Tranquilla",
        "url": websiteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${websiteUrl}/logo_512x512.jpg`
        }
      },
      "image": `${websiteUrl}/Profile.jpg`,
      "datePublished": frontmatter.date.replace(/\//g, "-"),
      "dateModified": frontmatter.dateModified?.replace(/\//g, "-") || frontmatter.date.replace(/\//g, "-"),
      "url": articleUrl,
      "keywords": frontmatter.tags.join(", "),
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": articleUrl
      }
    })} />
    <article>
      <header
        style={`view-transition-name: title-${i}`}
        class="mb-12 border-b border-[var(--border-primary)] pb-8 md:pb-12"
      >
        <h1
          class="text-wrap mb-3 text-3xl md:text-4xl font-serif font-semibold leading-tight text-[var(--text-primary)]"
          >{frontmatter.title}</h1
        >
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <span class="text-base text-[var(--text-muted)]">
            {frontmatter.author} · {frontmatter.date}
          </span>
          {frontmatter.tags.map((tag: string) => (
            <span class="rounded-full bg-[var(--bg-secondary)] px-2.5 py-0.5 text-xs font-medium text-[var(--text-tertiary)]">
              {tag}
            </span>
          ))}
        </div>
      </header>
      <section class="blog-body">
        <slot />
      </section>
      <footer class="mt-12 border-t border-[var(--border-primary)] pt-6">
        <ViewCount count={viewCount} />
      </footer>
    </article>
  </Container>
</Main>
