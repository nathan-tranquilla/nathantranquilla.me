---
import Main from "./Main.astro";
import Container from "../components/Container.astro";
import { getPostIndex } from "../utils/posts";

const { frontmatter } = Astro.props;

const i = getPostIndex(frontmatter.title);
---

<style is:global>
  /* Headings */
  .blog-post article h3 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-slate-900);
    font-family: var(--font-family-sans);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .blog-post article h4 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-slate-800);
    font-family: var(--font-family-sans);
    font-size: 1.125rem;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .blog-post article h3 {
      font-size: 1.5rem;
    }

    .blog-post article h4 {
      font-size: 1.25rem;
    }
  }

  /* Paragraphs */
  .blog-body p {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-gray-700);
    font-size: 1.125rem;
  }

  /* First paragraph in blog body */
  .blog-body > p:first-child {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-gray-800);
    line-height: 1.7;
  }

  /* Lists */
  .blog-post article ul {
    margin: 2rem 0;
    padding-left: 1.5rem;
    list-style: none;
  }

  .blog-post article ul li {
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.7;
    color: var(--color-gray-700);
  }

  .blog-post article ul li::before {
    content: "\25B8";
    color: var(--color-lime-900);
    font-weight: bold;
    position: absolute;
    left: 0;
    top: 0;
    font-size: 1.2rem;
  }

  /* Images */
  .blog-post article img {
    width: 100%;
    max-width: 900px;
    margin: 3rem auto;
    display: block;
    border-radius: 1rem;
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.25),
      0 10px 20px -8px rgba(0, 0, 0, 0.1);
    content-visibility: auto;
    border: 1px solid var(--color-slate-200);
  }

  /* Blockquotes */
  .blog-post article blockquote {
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    background: linear-gradient(135deg, var(--color-slate-50) 0%, var(--color-slate-100) 100%);
    border-left: 5px solid var(--color-lime-900);
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: var(--color-slate-600);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  /* Links */
  .blog-body a {
    color: var(--color-lime-900);
    text-decoration: underline;
    text-decoration-color: var(--color-lime-400);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .blog-body a:hover {
    color: var(--color-lime-950);
    text-decoration-color: var(--color-lime-900);
  }

  /* Strong text */
  .blog-body strong {
    color: var(--color-slate-800);
    font-weight: 700;
  }

  /* Tighten gap after headings */
  .blog-body h3 + p {
    margin-top: 1rem;
  }

  /* Blog post layout */
  .blog-post {
    min-height: 100vh;
  }
</style>
<Main title={`nathantraquilla.me | ${frontmatter.title}`}>
  <Container classes="blog-post w-full max-w-[1000px] mx-auto font-sans">
    <article>
      <header
        id={`article-${i}`}
        class="mb-12 border-b border-slate-200 pb-8 md:pb-12"
      >
        <h1
          class="text-wrap mb-3 text-3xl md:text-4xl font-bold leading-tight text-slate-900"
          >{frontmatter.title}</h1
        >
        <p class="text-base text-slate-500">
          {frontmatter.author} · {frontmatter.date}
        </p>
      </header>
      <section class="blog-body">
        <slot />
      </section>
    </article>
  </Container>
</Main>
