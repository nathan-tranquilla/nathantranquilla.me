---
import Main from "./Main.astro";
import Container from "../components/Container.astro";

const { frontmatter } = Astro.props;
---

<style is:global>
  .guide-body p {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  .guide-body > p:first-child {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .guide-body h3 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .guide-body h3 + p {
    margin-top: 1rem;
  }

  .guide-body ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
    list-style: decimal;
  }

  .guide-body ol li {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .guide-body ol li::marker {
    color: var(--accent-bg);
    font-weight: 600;
  }

  .guide-body strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  .notch {
    corner-shape: notch;
    border-radius: 8px;
  }
</style>

<Main
  title={`${frontmatter.title} | nathantranquilla.me`}
  description={frontmatter.description}
  breadcrumbTitle={frontmatter.title}
>
  <Container classes="w-full max-w-[680px] mx-auto font-sans">
    <h1 class="text-2xl md:text-3xl font-serif font-semibold text-[var(--text-primary)] mb-1">
      {frontmatter.title}
    </h1>
    {frontmatter.subtitle && (
      <p class="text-base text-[var(--text-muted)] mb-6">{frontmatter.subtitle}</p>
    )}

    <hr class="border-[var(--border-primary)] mb-2" />

    <section class="guide-body">
      <slot />
    </section>

    <hr class="border-[var(--border-primary)] mb-8" />

    <div class="grid md:grid-cols-2 gap-6 py-6">
      <div class="notch flex flex-col border border-[var(--border-primary)] hover:shadow-lg transition-shadow duration-200 p-6 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-[var(--text-muted)] mb-2">The Guide</p>
        <p class="text-lg font-serif font-semibold text-[var(--text-primary)] mb-2">Do it yourself</p>
        {frontmatter.pageCount && (
          <p class="text-sm text-[var(--text-muted)] mb-3">{frontmatter.pageCount}-page PDF reference</p>
        )}
        <ul class="text-left text-sm text-[var(--text-secondary)] space-y-2 mb-6 flex-1">
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Pricing breakdown by feature</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Questions to ask developers</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Red flags and green flags</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Compare quotes side by side</li>
        </ul>
        <p class="text-2xl font-semibold text-[var(--text-primary)] mb-4">
          {frontmatter.price} <span class="text-sm font-normal text-[var(--text-muted)]">USD</span>
        </p>
        <a
          class="gumroad-button inline-block rounded-md bg-[var(--accent-bg)] hover:bg-[var(--accent-bg-hover)] text-white py-3 px-6 font-semibold cursor-pointer hover:scale-[1.01] hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--accent-bg)] focus:ring-offset-2 shadow-md transition-[transform,box-shadow,background-color] duration-200 no-underline"
          href={frontmatter.gumroadUrl}
        >
          Buy the Guide
        </a>
      </div>

      <div class="notch flex flex-col border border-[var(--border-primary)] hover:shadow-lg transition-shadow duration-200 p-6 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-[var(--text-muted)] mb-2">Consultation</p>
        <p class="text-lg font-serif font-semibold text-[var(--text-primary)] mb-2">Work with me</p>
        <p class="text-sm text-[var(--text-muted)] mb-3">Hands-on guidance</p>
        <ul class="text-left text-sm text-[var(--text-secondary)] space-y-2 mb-6 flex-1">
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Review your quotes together</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Evaluate your Figma or design</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Scope the project correctly</li>
          <li class="flex gap-2"><span class="text-[var(--accent-bg)] shrink-0">&#10003;</span> Or I build the site for you</li>
        </ul>
        <p class="text-2xl font-semibold text-[var(--text-primary)] mb-4">
          Custom <span class="text-sm font-normal text-[var(--text-muted)]">quote</span>
        </p>
        <a
          class="inline-block rounded-md border-2 border-[var(--accent-bg)] text-[var(--accent-bg)] hover:bg-[var(--accent-bg)] hover:text-white py-3 px-6 font-semibold cursor-pointer hover:scale-[1.01] hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--accent-bg)] focus:ring-offset-2 transition-[transform,box-shadow,background-color,color] duration-200 no-underline"
          href="/consultation"
        >
          Book a Consultation
        </a>
      </div>
    </div>
  </Container>

  <script src="https://gumroad.com/js/gumroad.js" is:inline></script>
</Main>
